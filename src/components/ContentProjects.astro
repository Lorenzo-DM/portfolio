---
interface Project {
  name: string;
  description: string;
  link: {
    url?: string;
    target?: string;
    title?: string;
    buttonLabel?: string;
  };
}

const projects: Project[] = [
  {
    name: "Glossario Resiano",
    description:
      "A simple glossary to preserve and promote Resian, the language of my native country, in all its variants. Written in Vue and Flask.",
    link: {
      url: "https://glossarioresiano.it/",
    },
  },
  {
    name: "SempreVerde",
    description:
      "An informative website that displays mountain traffic light timings, so you can avoid waiting. Developed with Next.js.",
    link: {
      url: "https://semafero.vercel.app/",
    },
  },
  {
    name: "Lisuseum",
    description:
      "An accessible, innovative, and versatile museum guide. With automatic dubbing using AI models and an editor for articles. Developed with Next.js and Go Gin.",
    link: {
      url: "https://lisuseum.vercel.app/weaving-of-time",
    },
  },
];
---

<div>
  <!-- <h2 class="text-2xl font-bold text-white mb-4">Latest Projects</h2> -->

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {
      projects.map((project) => (
        <div class="flex flex-col justify-center items-start border border-gray-700 rounded-lg p-4 bg-black">
          <h3 class="text-xl font-semibold text-white mb-2">{project.name}</h3>

          <p class="text-gray-400">{project.description}</p>

          {project.link?.url ? (
            <a
              href={project.link.url}
              title={project.link.title || project.name}
              target={project.link.target || "_blank"}
              class="
                                w-full px-4 py-2.5 mt-4 text-center

                                border border-gray-600 rounded-lg

                                hover:text-primary
                                hover:border-primary
                            "
            >
              {project.link.buttonLabel || "Open Project Website"}
            </a>
          ) : null}
        </div>
      ))
    }
  </div>
</div>
