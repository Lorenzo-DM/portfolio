---
interface Props {
    href: string;
    contentName: string;
    isActive?: boolean;
};

const {
    href,
    contentName,
    isActive = false,
} = Astro.props;
---

<a
    href={href}
    class={[
        "tab-link",

        "flex items-center gap-2 py-2 px-4 text-xs cursor-pointer transition-all duration-200",

        "bg-black",
        "text-gray-100",
        isActive ? "text-primary border-b-2 border-primary bg-gray-900/50" : "hover:text-primary hover:bg-gray-900/20",

        "!border-r",
        "!border-r-gray-600"
    ].join(" ")}
>
    <svg fill=none height=16 stroke=currentColor stroke-linecap=round stroke-linejoin=round stroke-width=2 viewBox="0 0 24 24"width=16 xmlns=http://www.w3.org/2000/svg><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
    <h2>{contentName}</h2>
</a>