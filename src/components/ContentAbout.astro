---
import { Code } from "astro:components";

const softwareDev = `tech_stack:
  languages:
    - Python
    - JavaScript
    - Golang
    - C_Sharp
    - Bash
  web_development:
    backend:
      - Flask
      - Go_Gin
      - Express.js
      - Asp.NET
    frontend:
      - React
      - Next.js
      - Vue.js
      - TailwindCSS
    database:
      - Postgres
      - MySQL
      - MongoDB
      - SQLite
`;

const specialized = `specialized:
  devops:
    - Docker
    - Nginx
    - Ansible
    - Tailscale
    - GitHub_Actions
  embedded_systems:
    - Arduino
    - Raspberry_Pi
    - ESP32
  game_development:
    - Godot
    - Unity3D
    - LibreSprite
    - Krita
`;

const other = `other_interests:
  3d_printing:
    - Blender
    - Fusion360
    - Ultimaker_Cura
  hobbies:
    - Videogames
    - Self_Hosting
    - Open_Source
    - Cyber_Security
`;
---

<div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
  <!-- Main Column -->
  <div class="border border-gray-700/50 rounded-lg p-1 bg-gray-900/10">
    <Code code={softwareDev} lang="yaml" wrap={true} />
  </div>

  <!-- Secondary Column -->
  <div class="flex flex-col gap-4">
    <div class="border border-gray-700/50 rounded-lg p-1 bg-gray-900/10">
      <Code code={specialized} lang="yaml" wrap={true} />
    </div>
    <div class="border border-gray-700/50 rounded-lg p-1 bg-gray-900/10">
      <Code code={other} lang="yaml" wrap={true} />
    </div>
  </div>
</div>

<style is:global>
  /* Custom styling for code block line numbers */
  pre.astro-code {
    @apply bg-transparent !important;
  }

  pre.astro-code code {
    @apply block;
    counter-reset: step;
    counter-increment: step 0;
    padding: 0.8rem;
  }

  pre.astro-code code .line {
    @apply relative;
  }

  pre.astro-code code .line::before {
    content: counter(step);
    counter-increment: step;
    @apply text-gray-600 text-sm text-right inline-block;
    width: 1.5rem;
    margin-right: 1rem;
  }
</style>
