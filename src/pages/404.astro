---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="flex flex-col items-center justify-center p-8 text-center">
    <div class="bg-gray-900/50 border border-gray-700 rounded-lg p-8 max-w-lg w-full shadow-2xl">
      <div class="bg-red-500/10 border-l-4 border-red-500 p-4 mb-6 text-left">
        <h1 class="text-2xl font-bold text-red-500 mb-2">Error 404: Not Found</h1>
        <p class="text-gray-400 text-sm">
          The requested resource was not found on this server.
        </p>
      </div>

      <div class="font-mono text-left mb-8 space-y-2">
        <p class="text-primary tracking-tighter">
          <span class="text-gray-500">$</span> head -n 404 /tmp/current_location
        </p>
        <p class="text-red-400">
          cat: /tmp/current_location: No such file or directory
        </p>
        <p class="text-gray-600">
          <span class="text-gray-500">$</span> _
        </p>
      </div>

      <a
        href="/"
        class="inline-block px-8 py-3 border border-primary text-primary rounded-lg hover:bg-primary hover:text-black transition-all duration-200 font-bold"
      >
        cd /home/lorenzo
      </a>
    </div>
    
    <p class="mt-8 text-gray-500 text-xs uppercase tracking-widest">
      Lorenzo Della Mea Portfolio
    </p>
  </main>
</Layout>
